# Copy this file to .env and fill in your own values.
# .env is git-ignored and must NEVER be committed.

# Secret for signing JWT access tokens (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=replace-with-your-own-random-value

# Secret for Tornado secure cookies (legacy web handlers)
COOKIE_SECRET=replace-with-your-own-random-value

# Allowed CORS origin for the frontend
# Development:  http://localhost:3000
# Production:   https://your-domain.com
CORS_ORIGIN=http://localhost:3000

# Set to "true" when running behind HTTPS (marks cookies as Secure)
HTTPS=false
