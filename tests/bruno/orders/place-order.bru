meta {
  name: Place Order
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/orders
  body: json
  auth: none
}

body:json {
  {
    "product": "{{product}}",
    "side": "buy",
    "quantity": 10,
    "price": 100.0
  }
}

script:post-response {
  // Save orderId from response for use in other requests
  const data = res.getBody();
  if (data.orderId) {
    bru.setVar("orderId", data.orderId);
  }
}
