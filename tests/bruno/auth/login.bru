meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "test@example.com",
    "password": "heslo123"
  }
}

docs {
  ## Login

  Authenticates the user and issues a JWT access token + refresh token.

  **Body**
  | Field    | Type   | Required | Description        |
  |----------|--------|----------|--------------------|
  | email    | string | yes      | Registered e-mail  |
  | password | string | yes      | Plain-text password |

  **Responses**
  - `200` — `{ accessToken, tokenType: "Bearer", expiresIn: 900, email, userId }`
  - `400` — missing fields
  - `401` — invalid credentials

  **Side effects**
  - Sets `HttpOnly; SameSite=Strict` cookie `refresh_token` (valid 7 days)
  - Post-response script saves `accessToken` and `userId` to Bruno variables
}

script:post-response {
  // Save accessToken and userId for use in other requests
  const data = res.getBody();
  if (data.accessToken) {
    bru.setVar("accessToken", data.accessToken);
  }
  if (data.userId) {
    bru.setVar("userId", data.userId);
  }
}
